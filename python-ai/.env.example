# OpenAI API 配置（用于图片生成和语录生成）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com

# 或者使用 Stable Diffusion WebUI API
SD_WEBUI_URL=http://127.0.0.1:7860

# 图片风格配置
IMAGE_STYLE=anime  # anime | realistic | semi_realistic
IMAGE_SIZE=512x768 # 竖图适合社交媒体

# 生成器类型 (openai | sd)
GENERATOR_TYPE=openai

# 输出目录
OUTPUT_DIR=output
