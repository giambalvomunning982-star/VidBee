# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=dall-e-3

# Agnes AI API
AGNES_API_KEY=your_agnes_api_key_here
AGNES_API_BASE_URL=
AGNES_OPENAI_BASE_URL=
AGNES_IMAGE_API_URL=
AGNES_VIDEO_API_URL=https://apihub.agnes-ai.com/v1/chat/completions
AGNES_VIDEO_STATUS_URL_TEMPLATE=
AGNES_IMAGE_MODEL=
AGNES_VIDEO_MODEL=
AGNES_VIDEO_API_FORMAT=chat_completions

# Stable Diffusion WebUI (可选)
SD_WEBUI_URL=http://127.0.0.1:7860

# 图片风格配置
IMAGE_STYLE=anime  # anime | realistic | semi_realistic
IMAGE_SIZE=512x512

# 生成器类型 (openai | sd)
GENERATOR_TYPE=openai

# 输出目录
OUTPUT_DIR=output

# Video generation API
# These can point to Agnes AI or any compatible video generation provider.
VIDEO_API_URL=${AGNES_VIDEO_API_URL}
VIDEO_API_KEY=${AGNES_API_KEY}
VIDEO_MODEL=${AGNES_VIDEO_MODEL}
VIDEO_API_FORMAT=${AGNES_VIDEO_API_FORMAT}
VIDEO_OUTPUT_DIR=output/videos

# Optional. Use this when your provider requires polling on a different URL.
# The script replaces {task_id} with the id returned by VIDEO_API_URL.
VIDEO_STATUS_URL_TEMPLATE=${AGNES_VIDEO_STATUS_URL_TEMPLATE}
